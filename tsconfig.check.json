{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
    ,"types": ["node"]
  },
  "include": [
    "server/lib/templateService.js",
    "server/lib/workflowPatcher.js",
    "src/lib/template.js"
  ]
}
